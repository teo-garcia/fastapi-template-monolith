# Application
APP_NAME=FastAPI Monolith Template
APP_VERSION=1
DEBUG=false
PORT=8000
API_PREFIX=/api
SHUTDOWN_TIMEOUT=5

# Database (test database)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_monolith_test
DATABASE_ECHO=false
DATABASE_POOL_SIZE=2
DATABASE_MAX_OVERFLOW=0

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=60

# Logging
LOG_LEVEL=warning
LOG_JSON=false

# CORS
CORS_ENABLED=false
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_LIMIT=1000/minute

# Metrics
METRICS_ENABLED=false
