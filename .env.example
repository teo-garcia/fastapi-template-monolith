# Application
APP_NAME=FastAPI Monolith Template
APP_VERSION=1
DEBUG=false
PORT=8000
API_PREFIX=/api
SHUTDOWN_TIMEOUT=10

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_monolith
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# Logging
LOG_LEVEL=info
LOG_JSON=true

# CORS
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_LIMIT=100/minute

# Metrics
METRICS_ENABLED=true

# pgAdmin (docker only)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
